# Server-only FastAPI origin used by the authenticated Next.js BFF.
API_BASE_URL=http://localhost:8000

# Trusted public origin. Use HTTPS in production and never include a path.
NEXT_PUBLIC_SITE_ORIGIN=http://localhost:3000

# Optional Next.js mount point. Leave empty for root-path local development.
# Production uses /careersignals (no trailing slash).
NEXT_PUBLIC_BASE_PATH=

# Server-only HMAC secret for short-lived password-recovery intent cookies.
# Generate a unique random value of at least 32 bytes for each environment.
PASSWORD_RECOVERY_COOKIE_SECRET=

# Public browser metadata. Never place a Supabase service-role key here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_BROWSER_KEY
