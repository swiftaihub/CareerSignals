{
  "name": "careersignal-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "build": "next build",
    "start": "next start",
    "build:opennext": "opennextjs-cloudflare build && node scripts/prepare-cloudflare-assets.mjs",
    "preview:cloudflare": "npm run build:opennext && opennextjs-cloudflare preview",
    "deploy:cloudflare": "npm run build:opennext && opennextjs-cloudflare deploy",
    "upload:cloudflare": "npm run build:opennext && opennextjs-cloudflare upload"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.9.2",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@eslint/eslintrc": "^3.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4",
    "wrangler": "4.110.0"
  }
}
