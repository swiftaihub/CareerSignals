CAREERSIGNAL_DATA_MODE=local

MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=CareerSignal

CAREERSIGNAL_LOCAL_DATA_DIR=data
CAREERSIGNAL_OUTPUT_DIR=outputs
CAREERSIGNAL_EXCEL_PATH=outputs/job_search_tracker.xlsx
CAREERSIGNAL_WRITE_DEBUG_JSON=false

DBT_PROJECT_DIR=dbt
DBT_PROFILES_DIR=dbt
DBT_TARGET=local
CAREERSIGNAL_RUN_DBT=true
CAREERSIGNAL_RUN_DBT_TESTS=true

# CareerSignal source selection.
# The project runs with mock/sample data when real source settings are absent.

# Comma-separated values: mock, adzuna, serpapi, greenhouse, lever, usajobs
# Use "all" to try all real API connectors. If no real data returns, mock fallback is used.
JOB_SOURCES=mock
CONNECTOR_TIMEOUT_SECONDS=15

# Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_RESULTS_PER_PAGE=25
ADZUNA_MAX_PAGES=1
ADZUNA_MAX_QUERIES_PER_CATEGORY=4

# SerpApi Google Jobs
SERPAPI_API_KEY=
SERPAPI_MAX_QUERIES_PER_CATEGORY=1
SERPAPI_GOOGLE_DOMAIN=google.com
SERPAPI_GL=us
SERPAPI_HL=en

# Greenhouse public Job Board API.
# Values are company board tokens from boards.greenhouse.io/{token}.
GREENHOUSE_COMPANY_TOKENS=

# Lever public postings API.
# Values are company site names from jobs.lever.co/{site}.
LEVER_COMPANY_SITES=

# USAJOBS Search API.
# Request credentials from developer.usajobs.gov.
USAJOBS_USER_AGENT=
USAJOBS_API_KEY=
USAJOBS_RESULTS_PER_PAGE=25
USAJOBS_MAX_QUERIES_PER_CATEGORY=2
