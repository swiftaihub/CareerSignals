CAREERSIGNAL_SAAS_MODE=true
CAREERSIGNAL_ENVIRONMENT=development
CAREERSIGNAL_DATA_MODE=postgres

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
SUPABASE_JWKS_URL=
DATABASE_URL=

ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

DEMO_USER_UUID=00000000-0000-4000-8000-000000000020
DEMO_SESSION_SECRET=replace-with-32-plus-byte-random-secret
DEMO_SESSION_TTL_MINUTES=60

CONNECTOR_REFRESH_CRON=0 */6 * * *
CONNECTOR_REFRESH_TIMEZONE=UTC
CONNECTOR_STALE_AFTER_HOURS=8

USER_PIPELINE_DAILY_LIMIT=
USER_PIPELINE_MAX_CONCURRENCY=1
USER_PIPELINE_POLL_SECONDS=2

CORS_ORIGINS=http://localhost:3000
SCHEDULER_INTERNAL_SECRET=
LOG_LEVEL=INFO

MOTHERDUCK_TOKEN=
MOTHERDUCK_DATABASE=CareerSignal

CAREERSIGNAL_LOCAL_DATA_DIR=data
CAREERSIGNAL_OUTPUT_DIR=outputs
CAREERSIGNAL_EXCEL_PATH=outputs/job_search_tracker.xlsx
CAREERSIGNAL_WRITE_DEBUG_JSON=false
CAREERSIGNAL_EXPORT_EXCEL=false
CAREERSIGNAL_PROGRESS=true
CAREERSIGNAL_MOTHERDUCK_BATCH_SIZE=1000

DBT_PROJECT_DIR=dbt
DBT_PROFILES_DIR=dbt
DBT_TARGET=dev
CAREERSIGNAL_RUN_DBT=true
CAREERSIGNAL_RUN_DBT_TESTS=true
CAREERSIGNAL_DBT_FULL_REFRESH=false

# CareerSignal source selection.
# The project runs with mock/sample data when real source settings are absent.

# Comma-separated values: mock, adzuna, serpapi, greenhouse, lever, usajobs
# Use "all" to try all real API connectors. If no real data returns, mock fallback is used.
JOB_SOURCES=mock
CONNECTOR_TIMEOUT_SECONDS=15

# Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
ADZUNA_RESULTS_PER_PAGE=25
ADZUNA_MAX_PAGES=1
ADZUNA_MAX_QUERIES_PER_CATEGORY=4

# SerpApi Google Jobs
SERPAPI_API_KEY=
SERPAPI_MAX_QUERIES_PER_CATEGORY=1
SERPAPI_GOOGLE_DOMAIN=google.com
SERPAPI_GL=us
SERPAPI_HL=en

# Greenhouse public Job Board API.
# Values are company board tokens from boards.greenhouse.io/{token}.
GREENHOUSE_COMPANY_TOKENS=

# Lever public postings API.
# Values are company site names from jobs.lever.co/{site}.
LEVER_COMPANY_SITES=

# USAJOBS Search API.
# Request credentials from developer.usajobs.gov.
USAJOBS_USER_AGENT=
USAJOBS_API_KEY=
USAJOBS_RESULTS_PER_PAGE=25
USAJOBS_MAX_QUERIES_PER_CATEGORY=2

SUPABASE_REGION=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_DIRECT_URL=
SUPABASE_DB_SESSION_URL=

TEST_USER_A_USER_UUID=
TEST_USER_B_USER_UUID=

TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=

TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=

# Only needed if CLI is not already logged in interactively
SUPABASE_ACCESS_TOKEN=
